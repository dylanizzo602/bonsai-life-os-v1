# Supabase (copy to .env and fill with your project values)
# Get these from: Supabase project → Settings → API
VITE_SUPABASE_URL=https://xmfueuzciysragntnyoz.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhtZnVldXpjaXlzcmFnbnRueW96Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA3NTIyNTAsImV4cCI6MjA4NjMyODI1MH0.2zAVqiXmOjD0y1DAt5-6LaMVe-_oOzmqJ-zIDU6ZbU4

# Web Push (PWA)
# Public VAPID key used by the browser to create a PushManager subscription.
# Generate via: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY_BASE64URL

# Push Sender (Vercel function)
# Used by the Supabase notifications edge function when calling your deployed sender.
NOTIFICATIONS_PUSH_API_KEY=YOUR_PUSH_API_KEY
# Used by the sender to send Web Push messages.
NOTIFICATIONS_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY_BASE64URL
NOTIFICATIONS_VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
NOTIFICATIONS_VAPID_SUBJECT=mailto:you@domain.com

# Google Calendar OAuth (Supabase Edge Functions)
# These are set as Edge Function secrets in Supabase (server-side), not in the browser.
GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
# Redirect URL must match your Google OAuth client configuration and point to the callback Edge Function.
GOOGLE_OAUTH_REDIRECT_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/google-oauth-callback
# Used to sign/verify the OAuth state param (keep secret).
GOOGLE_OAUTH_STATE_SECRET=YOUR_RANDOM_LONG_SECRET
# Used by the callback to redirect the user back to the app after connecting.
APP_BASE_URL=http://localhost:5173
